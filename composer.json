{
    "name": "botdigit/cryptogateway",
    "description": "An open-source all-in-one cryptocurrency payment gateway package for Laravel supporting BTC, ETH, TRX, SOL, LTC, BNB, USDT, and USDC.",
    "keywords": [
        "laravel",
        "cryptocurrency",
        "payment-gateway",
        "bitcoin",
        "ethereum",
        "usdt",
        "solana",
        "tron",
        "blockchain",
        "composer-package",
        "crypto-payments",
        "web3-laravel",
        "erc20",
        "trc20",
        "litecoin",
        "bnb"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Botdigit",
            "email": "dev@botdigit.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/events": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/encryption": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/cache": "^10.0|^11.0|^12.0",
        "illuminate/log": "^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Botdigit\\CryptoGateway\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Botdigit\\CryptoGateway\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Botdigit\\CryptoGateway\\CryptoGatewayServiceProvider"
            ],
            "aliases": {
                "CryptoGateway": "Botdigit\\CryptoGateway\\Facades\\CryptoGateway"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
